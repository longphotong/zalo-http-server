# Cổng và địa chỉ server (mặc định: 3099, 127.0.0.1)
PORT=3099
HOST=127.0.0.1

# Profile xác thực Zalo (mặc định: default)
# Tương ứng với file credentials-<profile>.json trong OPENCLAW_CREDENTIALS_DIR
ZALO_PROFILE=default

# Thư mục chứa file credentials của OpenClaw zalouser
# Mặc định: ~/.openclaw/credentials/zalouser
# OPENCLAW_CREDENTIALS_DIR=/home/user/.openclaw/credentials/zalouser

# (Tuỳ chọn) Đường dẫn trực tiếp đến thư mục zca-js
# Dùng khi zca-js không nằm trong vị trí mặc định của OpenClaw
# ZCA_JS_PATH=/path/to/zca-js

# (Tuỳ chọn) Thư mục extensions của OpenClaw
# Dùng khi OpenClaw được cài ở vị trí không chuẩn
# OPENCLAW_EXTENSIONS_DIR=/path/to/openclaw/extensions
